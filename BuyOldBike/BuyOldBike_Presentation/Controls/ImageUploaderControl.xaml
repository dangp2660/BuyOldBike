<UserControl x:Class="BuyOldBike_Presentation.Controls.ImageUploaderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="200">
    <Border Padding="8" BorderBrush="Gray" BorderThickness="1">
        <StackPanel>
            <Button Name="BtnSelect" Content="Select Images..." Width="140" Margin="0,0,0,8" />
            <ScrollViewer Height="120">
                <ItemsControl Name="Thumbnails">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderThickness="1" BorderBrush="LightGray" Margin="4">
                                <Image Source="{Binding}" Width="100" Height="80" Stretch="UniformToFill" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>
    </Border>
</UserControl>