<UserControl x:Class="BuyOldBike_Presentation.Controls.PaginationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="44"
             d:DesignWidth="460">
    <Border Padding="10"
            Background="White"
            CornerRadius="12"
            BorderBrush="#E5E7EB"
            BorderThickness="1">
        <StackPanel HorizontalAlignment="Center"
                    Orientation="Horizontal">
            <Button MinWidth="80"
                    Height="34"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Content="Trước" />

            <Button Margin="10,0,0,0"
                    MinWidth="34"
                    Height="34"
                    Content="1" />
            <Button Margin="8,0,0,0"
                    MinWidth="34"
                    Height="34"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Content="2" />
            <Button Margin="8,0,0,0"
                    MinWidth="34"
                    Height="34"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Content="3" />

            <Button Margin="10,0,0,0"
                    MinWidth="80"
                    Height="34"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Content="Sau" />
        </StackPanel>
    </Border>
</UserControl>
