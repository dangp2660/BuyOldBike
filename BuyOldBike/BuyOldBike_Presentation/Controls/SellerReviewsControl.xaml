<UserControl x:Class="BuyOldBike_Presentation.Controls.SellerReviewsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="800">
    <Border Padding="20"
            Background="White"

            BorderBrush="#E5E7EB"
            BorderThickness="1">
        <StackPanel>
            <!-- Header with ratings -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <TextBlock FontSize="28"
                               FontWeight="Bold"
                               Foreground="#1F2937"
                               x:Name="AverageRatingText"
                               Text="4.5" />
                    <TextBlock FontSize="12"
                               Foreground="#6B7280"
                               x:Name="TotalReviewsText"
                               Text="24 đánh giá" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="20,0,0,0" Orientation="Vertical">
                    <!-- Rating bars -->
                    <Grid Height="20" Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="5★" Width="30" Foreground="#F59E0B" FontWeight="Bold" />
                        <Border Grid.Column="1" Margin="10,0" Background="#E5E7EB">
                            <Border Background="#10B981" x:Name="Rating5Bar" Width="80%" HorizontalAlignment="Left" />
                        </Border>
                        <TextBlock Grid.Column="2" x:Name="Rating5Count" Text="0" Width="30" TextAlignment="Right" />
                    </Grid>

                    <Grid Height="20" Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="4★" Width="30" Foreground="#F59E0B" FontWeight="Bold" />
                        <Border Grid.Column="1" Margin="10,0" Background="#E5E7EB">
                            <Border Background="#10B981" x:Name="Rating4Bar" Width="50%" HorizontalAlignment="Left" />
                        </Border>
                        <TextBlock Grid.Column="2" x:Name="Rating4Count" Text="0" Width="30" TextAlignment="Right" />
                    </Grid>

                    <Grid Height="20" Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="3★" Width="30" Foreground="#F59E0B" FontWeight="Bold" />
                        <Border Grid.Column="1" Margin="10,0" Background="#E5E7EB">
                            <Border Background="#10B981" x:Name="Rating3Bar" Width="30%" HorizontalAlignment="Left" />
                        </Border>
                        <TextBlock Grid.Column="2" x:Name="Rating3Count" Text="0" Width="30" TextAlignment="Right" />
                    </Grid>

                    <Grid Height="20" Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="2★" Width="30" Foreground="#F59E0B" FontWeight="Bold" />
                        <Border Grid.Column="1" Margin="10,0" Background="#E5E7EB">
                            <Border Background="#10B981" x:Name="Rating2Bar" Width="10%" HorizontalAlignment="Left" />
                        </Border>
                        <TextBlock Grid.Column="2" x:Name="Rating2Count" Text="0" Width="30" TextAlignment="Right" />
                    </Grid>

                    <Grid Height="20" Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="1★" Width="30" Foreground="#F59E0B" FontWeight="Bold" />
                        <Border Grid.Column="1" Margin="10,0" Background="#E5E7EB">
                            <Border Background="#10B981" x:Name="Rating1Bar" Width="5%" HorizontalAlignment="Left" />
                        </Border>
                        <TextBlock Grid.Column="2" x:Name="Rating1Count" Text="0" Width="30" TextAlignment="Right" />
                    </Grid>
                </StackPanel>
            </Grid>

            <Separator Background="#E5E7EB" Margin="0,0,0,24" />

            <!-- Reviews List -->
            <TextBlock FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#1F2937"
                       Text="Đánh giá chi tiết"
                       Margin="0,0,0,16" />

            <ListBox x:Name="ReviewsListBox"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     MaxHeight="600">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12"
                                Margin="0,0,0,12"
                                Background="#F9FAFB"
                               
                                BorderBrush="#E5E7EB"
                                BorderThickness="1">
                            <StackPanel Orientation="Vertical">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Vertical">
                                        <TextBlock FontWeight="Bold"
                                                   Foreground="#1F2937"
                                                   Text="{Binding BuyerName}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding Rating}"
                                                       Foreground="#F59E0B"
                                                       FontWeight="Bold" />
                                            <TextBlock Text="★"
                                                       Foreground="#F59E0B"
                                                       FontWeight="Bold"
                                                       Margin="2,0,0,0" />
                                            <TextBlock Margin="8,0,0,0"
                                                       Foreground="#6B7280"
                                                       FontSize="12"
                                                       Text="{Binding CreatedAt, StringFormat='dd/MM/yyyy'}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1"
                                               Foreground="#6B7280"
                                               FontSize="12"
                                               Text="{Binding BuyerEmail}" />
                                </Grid>

                                <TextBlock Margin="0,8,0,0"
                                           Foreground="#374151"
                                           TextWrapping="Wrap"
                                           Text="{Binding Description}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Empty state -->
            <StackPanel Margin="20" Orientation="Vertical" HorizontalAlignment="Center" x:Name="EmptyStatePanel" Visibility="Collapsed">
                <TextBlock HorizontalAlignment="Center"
                           FontSize="14"
                           Foreground="#6B7280"
                           Text="Chưa có đánh giá nào" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
