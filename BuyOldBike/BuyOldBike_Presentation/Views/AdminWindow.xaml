<Window x:Class="BuyOldBike_Presentation.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Khu vực Admin"
        Width="1280"
        Height="820"
        MinWidth="1100"
        MinHeight="680"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <XmlDataProvider x:Key="AdminUsersProvider" XPath="/Items/Item">
            <x:XData>
                <Items xmlns="">
                    <Item Name="Nguyễn Văn A" Email="a.nguyen@example.com" Role="Seller" Status="Active" />
                    <Item Name="Trần Thị B" Email="b.tran@example.com" Role="Buyer" Status="Active" />
                    <Item Name="Lê Văn C" Email="c.le@example.com" Role="Inspector" Status="Suspended" />
                    <Item Name="Phạm D" Email="d.pham@example.com" Role="Seller" Status="Active" />
                </Items>
            </x:XData>
        </XmlDataProvider>

        <XmlDataProvider x:Key="ModerationListingsProvider" XPath="/Items/Item">
            <x:XData>
                <Items xmlns="">
                    <Item Title="Giant TCR 2021 - Like new" Seller="Nguyễn Văn A" DatePosted="12/03/2026" Status="Pending" />
                    <Item Title="Trek Domane SL5" Seller="Phạm D" DatePosted="10/03/2026" Status="Pending" />
                    <Item Title="Specialized Allez" Seller="Lê Văn C" DatePosted="09/03/2026" Status="Flagged" />
                </Items>
            </x:XData>
        </XmlDataProvider>

        <XmlDataProvider x:Key="TransactionsProvider" XPath="/Items/Item">
            <x:XData>
                <Items xmlns="">
                    <Item TxId="TX-00421" Buyer="Trần Thị B" Seller="Nguyễn Văn A" Amount="15,000,000" Status="Completed" Date="08/03/2026" />
                    <Item TxId="TX-00435" Buyer="Đỗ E" Seller="Phạm D" Amount="9,800,000" Status="Processing" Date="12/03/2026" />
                    <Item TxId="TX-00440" Buyer="Hồ F" Seller="Lê Văn C" Amount="6,500,000" Status="Disputed" Date="13/03/2026" />
                </Items>
            </x:XData>
        </XmlDataProvider>

        <XmlDataProvider x:Key="BicycleCategoriesProvider" XPath="/Items/Item">
            <x:XData>
                <Items xmlns="">
                    <Item Name="Road" />
                    <Item Name="MTB" />
                    <Item Name="Hybrid" />
                    <Item Name="City" />
                </Items>
            </x:XData>
        </XmlDataProvider>

        <XmlDataProvider x:Key="BrandsProvider" XPath="/Items/Item">
            <x:XData>
                <Items xmlns="">
                    <Item Name="Giant" />
                    <Item Name="Trek" />
                    <Item Name="Specialized" />
                    <Item Name="Cannondale" />
                </Items>
            </x:XData>
        </XmlDataProvider>

        <XmlDataProvider x:Key="FrameSizesProvider" XPath="/Items/Item">
            <x:XData>
                <Items xmlns="">
                    <Item Name="48" />
                    <Item Name="50" />
                    <Item Name="52" />
                    <Item Name="54" />
                    <Item Name="56" />
                </Items>
            </x:XData>
        </XmlDataProvider>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#FFE5E7EB"
                BorderThickness="0,0,0,1"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Admin Center" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#FF6B7280"
                               Text="Quản trị người dùng, bài đăng, danh mục và giao dịch" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Height="40" MinWidth="130" Content="Xem hồ sơ" />
                    <Button Margin="12,0,0,0" Height="40" MinWidth="130" Content="Đăng xuất" Click="BtnLogout_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="16" Background="{x:Null}">
            <TabItem Header="Dashboard">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Tổng quan hệ thống" />

                        <Grid Margin="0,12,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Row="0" Grid.Column="0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                <StackPanel>
                                    <TextBlock Foreground="#FF6B7280" Text="Total Users" />
                                    <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Text="1,248" />
                                    <TextBlock Margin="0,8,0,0" Foreground="#FF6B7280" Text="Tổng số người dùng" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="2" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                <StackPanel>
                                    <TextBlock Foreground="#FF6B7280" Text="Active Listings" />
                                    <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Text="312" />
                                    <TextBlock Margin="0,8,0,0" Foreground="#FF6B7280" Text="Bài đăng đang hoạt động" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Grid.Column="0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                <StackPanel>
                                    <TextBlock Foreground="#FF6B7280" Text="Total Transactions" />
                                    <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Text="842" />
                                    <TextBlock Margin="0,8,0,0" Foreground="#FF6B7280" Text="Tổng số giao dịch" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Grid.Column="2" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                <StackPanel>
                                    <TextBlock Foreground="#FF6B7280" Text="System Revenue" />
                                    <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Text="128,500,000" />
                                    <TextBlock Margin="0,8,0,0" Foreground="#FF6B7280" Text="Doanh thu hệ thống (VND)" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Margin="0,16,0,0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                            <StackPanel>
                                <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Hoạt động gần đây" />
                                <TextBlock Margin="0,4,0,0" Foreground="#FF6B7280" Text="Một số sự kiện mẫu để minh hoạ" />

                                <ListBox Margin="0,12,0,0">
                                    <ListBoxItem Content="12/03 - 3 listing mới đang chờ duyệt" />
                                    <ListBoxItem Content="13/03 - 1 giao dịch chuyển sang trạng thái Disputed" />
                                    <ListBoxItem Content="13/03 - 2 user bị suspend do vi phạm" />
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="User Management">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="User Management" />

                        <Border Margin="0,12,0,0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="140" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0" Text="Tìm theo tên / email..." />
                                    <ComboBox Grid.Column="2" SelectedIndex="0">
                                        <ComboBoxItem Content="All roles" />
                                        <ComboBoxItem Content="Buyer" />
                                        <ComboBoxItem Content="Seller" />
                                        <ComboBoxItem Content="Inspector" />
                                        <ComboBoxItem Content="Admin" />
                                    </ComboBox>
                                    <ComboBox Grid.Column="4" SelectedIndex="0">
                                        <ComboBoxItem Content="All status" />
                                        <ComboBoxItem Content="Active" />
                                        <ComboBoxItem Content="Suspended" />
                                    </ComboBox>
                                </Grid>

                                <DataGrid Margin="0,12,0,0"
                                          Height="480"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserResizeRows="False"
                                          CanUserReorderColumns="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          SelectionUnit="FullRow"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="None"
                                          RowHeaderWidth="0"
                                          BorderBrush="#FFE5E7EB"
                                          BorderThickness="1"
                                          Background="White"
                                          RowBackground="White"
                                          AlternatingRowBackground="#FFF9FAFB"
                                          ItemsSource="{Binding Source={StaticResource AdminUsersProvider}}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="User Name" Width="220" Binding="{Binding XPath=@Name}" />
                                        <DataGridTextColumn Header="Email" Width="260" Binding="{Binding XPath=@Email}" />
                                        <DataGridTextColumn Header="Role" Width="120" Binding="{Binding XPath=@Role}" />
                                        <DataGridTextColumn Header="Status" Width="120" Binding="{Binding XPath=@Status}" />
                                        <DataGridTemplateColumn Header="Actions" Width="220">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                        <Button Height="28" Padding="10,4" Content="Suspend" />
                                                        <Button Margin="8,0,0,0" Height="28" Padding="10,4" Content="Activate" />
                                                        <Button Margin="8,0,0,0" Height="28" Padding="10,4" Content="View Profile" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Listing Moderation">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Listing Moderation" />

                        <Border Margin="0,12,0,0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="160" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0" Text="Tìm theo tiêu đề / seller..." />
                                    <ComboBox Grid.Column="2" SelectedIndex="0">
                                        <ComboBoxItem Content="All status" />
                                        <ComboBoxItem Content="Pending" />
                                        <ComboBoxItem Content="Approved" />
                                        <ComboBoxItem Content="Rejected" />
                                        <ComboBoxItem Content="Flagged" />
                                    </ComboBox>
                                    <Button Grid.Column="4" Content="Làm mới" />
                                </Grid>

                                <DataGrid Margin="0,12,0,0"
                                          Height="480"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserResizeRows="False"
                                          CanUserReorderColumns="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          SelectionUnit="FullRow"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="None"
                                          RowHeaderWidth="0"
                                          BorderBrush="#FFE5E7EB"
                                          BorderThickness="1"
                                          Background="White"
                                          RowBackground="White"
                                          AlternatingRowBackground="#FFF9FAFB"
                                          ItemsSource="{Binding Source={StaticResource ModerationListingsProvider}}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Listing Title" Width="340" Binding="{Binding XPath=@Title}" />
                                        <DataGridTextColumn Header="Seller" Width="180" Binding="{Binding XPath=@Seller}" />
                                        <DataGridTextColumn Header="Date Posted" Width="140" Binding="{Binding XPath=@DatePosted}" />
                                        <DataGridTextColumn Header="Status" Width="120" Binding="{Binding XPath=@Status}" />
                                        <DataGridTemplateColumn Header="Buttons" Width="240">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                        <Button Height="28" Padding="10,4" Content="Approve" />
                                                        <Button Margin="8,0,0,0" Height="28" Padding="10,4" Content="Reject" />
                                                        <Button Margin="8,0,0,0" Height="28" Padding="10,4" Content="Remove" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Category Management">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Category Management" />

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Bicycle Categories" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Height="28" Padding="10,4" Content="Add" />
                                            <Button Margin="8,0,0,0" Height="28" Padding="10,4" Content="Edit" />
                                            <Button Margin="8,0,0,0" Height="28" Padding="10,4" Content="Delete" />
                                        </StackPanel>
                                    </Grid>
                                    <ListBox Margin="0,12,0,0" Height="420" ItemsSource="{Binding Source={StaticResource BicycleCategoriesProvider}}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding XPath=@Name}" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Brands" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Height="28" Padding="10,4" Content="Add" />
                                            <Button Margin="8,0,0,0" Height="28" Padding="10,4" Content="Edit" />
                                            <Button Margin="8,0,0,0" Height="28" Padding="10,4" Content="Delete" />
                                        </StackPanel>
                                    </Grid>
                                    <ListBox Margin="0,12,0,0" Height="420" ItemsSource="{Binding Source={StaticResource BrandsProvider}}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding XPath=@Name}" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Frame Sizes" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Height="28" Padding="10,4" Content="Add" />
                                            <Button Margin="8,0,0,0" Height="28" Padding="10,4" Content="Edit" />
                                            <Button Margin="8,0,0,0" Height="28" Padding="10,4" Content="Delete" />
                                        </StackPanel>
                                    </Grid>
                                    <ListBox Margin="0,12,0,0" Height="420" ItemsSource="{Binding Source={StaticResource FrameSizesProvider}}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding XPath=@Name}" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Transaction Management">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Transaction Management" />

                        <Border Margin="0,12,0,0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="140" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0" Text="Tìm theo transaction / buyer / seller..." />
                                    <ComboBox Grid.Column="2" SelectedIndex="0">
                                        <ComboBoxItem Content="All status" />
                                        <ComboBoxItem Content="Completed" />
                                        <ComboBoxItem Content="Processing" />
                                        <ComboBoxItem Content="Disputed" />
                                        <ComboBoxItem Content="Refunded" />
                                    </ComboBox>
                                    <Button Grid.Column="4" Content="Export" />
                                </Grid>

                                <DataGrid Margin="0,12,0,0"
                                          Height="480"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserResizeRows="False"
                                          CanUserReorderColumns="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          SelectionUnit="FullRow"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="None"
                                          RowHeaderWidth="0"
                                          BorderBrush="#FFE5E7EB"
                                          BorderThickness="1"
                                          Background="White"
                                          RowBackground="White"
                                          AlternatingRowBackground="#FFF9FAFB"
                                          ItemsSource="{Binding Source={StaticResource TransactionsProvider}}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Transaction ID" Width="130" Binding="{Binding XPath=@TxId}" />
                                        <DataGridTextColumn Header="Buyer" Width="160" Binding="{Binding XPath=@Buyer}" />
                                        <DataGridTextColumn Header="Seller" Width="160" Binding="{Binding XPath=@Seller}" />
                                        <DataGridTextColumn Header="Amount" Width="130" Binding="{Binding XPath=@Amount}" />
                                        <DataGridTextColumn Header="Status" Width="120" Binding="{Binding XPath=@Status}" />
                                        <DataGridTextColumn Header="Date" Width="120" Binding="{Binding XPath=@Date}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
