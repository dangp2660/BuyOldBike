                                    <Border Height="90"
                                            Background="#F3F4F6"
                                            CornerRadius="10"
                                            ClipToBounds="True">
                                        <Grid>
                                            <Image Source="{Binding FirstImageUrl, Converter={StaticResource ImageUrlToBitmapImageConverter}}"
