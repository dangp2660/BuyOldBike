                                    Padding="10"
                                    Background="White"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="ListingCard_MouseLeftButtonUp"
                                    VerticalAlignment="Top">
