<Window x:Class="BuyOldBike_Presentation.Views.BicycleListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:BuyOldBike_Presentation.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Danh sách xe"        
        Width="1600"
        Height="800"
        MinWidth="1024"
        MinHeight="640"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:ImageUrlToBitmapImageConverter x:Key="ImageUrlToBitmapImageConverter" />
    </Window.Resources>

    <Grid Background="#F9FAFB">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,0,1"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Height="40" VerticalContentAlignment="Center" Padding="12,0" Text="Tìm xe theo tên..." />
                    <Button Grid.Column="2" Height="40" MinWidth="90" Content="Tìm" />
                </Grid>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Margin="12,0,0,0"
                            Height="40"
                            MinWidth="120"
                            Content="Bộ lọc" />
                    <Button Margin="12,0,0,0"
                            Height="40"
                            MinWidth="120"
                            Content="Đăng nhập"
                            Name="btnLogin"
                            Click="btnLogin_Click" />
                    <Button Margin="12,0,0,0"
                            Height="40"
                            MinWidth="40"
                            Padding="10,0"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Content="👤"
                            Name="btnProfile"
                            Visibility="Collapsed"
                            Click="btnProfile_Click">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Hồ sơ eKYC" Click="MenuProfile_Click" />
                                <MenuItem Header="Đăng xuất" Click="MenuLogout_Click" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="260" MaxWidth="360" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Bộ lọc" />
                    <TextBlock Margin="0,8,0,0" Foreground="#FF6B7280" Text="Hãng" />
                    <ComboBox Margin="0,6,0,0" SelectedIndex="0">
                        <ComboBoxItem Content="Tất cả" />
                    </ComboBox>
                    <TextBlock Margin="0,12,0,0" Foreground="#FF6B7280" Text="Loại xe" />
                    <ComboBox Margin="0,6,0,0" SelectedIndex="0">
                        <ComboBoxItem Content="Tất cả" />
                    </ComboBox>
                    <TextBlock Margin="0,12,0,0" Foreground="#FF6B7280" Text="Trạng thái kiểm định" />
                    <StackPanel Margin="0,6,0,0">
                        <CheckBox Content="Đã kiểm định" />
                        <CheckBox Margin="0,6,0,0" Content="Chưa kiểm định" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
