                               Text="{Binding CurrentPage, StringFormat=Trang {0}}" />

                    <Button MinWidth="90"
                            Height="34"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="Sau"
                            Click="NextPage_Click" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
