                                        <Border Padding="8,4"
                                                Background="#ECFDF5"
                                                CornerRadius="999">
                                            <TextBlock Foreground="#047857"
                                                       FontSize="12"
                                                       Text="Đã kiểm định" />
                                        </Border>
                                        <Button Margin="10,0,0,0"
                                                MinWidth="34"
                                                Height="28"
                                                Padding="8,4"
                                                Content="♥" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
