                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="#6B7280"
                                                       Text="Ảnh xe">
                                            </TextBlock>
                                        </Grid>
                                    </Border>

