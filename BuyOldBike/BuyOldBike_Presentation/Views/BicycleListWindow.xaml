                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Text="{Binding Title}" />
                                    <TextBlock Margin="0,4,0,0"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Text="{Binding Price, StringFormat={}{0:N0}đ}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#6B7280"
                                               Text="{Binding MetaText}" />

