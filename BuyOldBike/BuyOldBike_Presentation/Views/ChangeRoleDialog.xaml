<Window x:Class="BuyOldBike_Presentation.Views.ChangeRoleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đổi vai trò"
        Width="320" Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="16" FontWeight="SemiBold"
                   Text="Chọn role mới"/>

        <TextBlock Grid.Row="2" Foreground="#FF6B7280"
                   x:Name="TxtCurrentRole"/>

        <ComboBox Grid.Row="4" x:Name="CmbNewRole" SelectedIndex="0">
            <ComboBoxItem Content="Buyer"     Tag="Buyer"/>
            <ComboBoxItem Content="Seller"    Tag="Seller"/>
            <ComboBoxItem Content="Inspector" Tag="Inspector"/>
            <ComboBoxItem Content="Admin"     Tag="Admin"/>
        </ComboBox>

        <StackPanel Grid.Row="6" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="80" Height="34"
                    Content="Huỷ" Click="BtnCancel_Click"/>
            <Button Margin="12,0,0,0" Width="80" Height="34"
                    Content="Xác nhận" Click="BtnConfirm_Click"/>
        </StackPanel>
    </Grid>
</Window>