<Window x:Class="BuyOldBike_Presentation.Views.CreateDisputeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:BuyOldBike_Presentation.Converters"
        Title="Tạo Khiếu Nại" Height="520" Width="420" WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <converters:ImageUrlToBitmapImageConverter x:Key="ImageUrlToBitmapImageConverter" />
    </Window.Resources>
    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Khiếu nại xe không đúng cam kết" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Lý do khiếu nại:" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <ComboBox Grid.Row="2" Name="cmbReason" Margin="0,0,0,15" Height="30">
            <ComboBoxItem Content="Xe bị hỏng hóc nặng" IsSelected="True"/>
            <ComboBoxItem Content="Sai thông tin (màu sắc, đời xe, ...)"/>
            <ComboBoxItem Content="Giấy tờ không hợp lệ"/>
            <ComboBoxItem Content="Lý do khác"/>
        </ComboBox>

        <TextBlock Grid.Row="3" Text="Chi tiết (bằng chứng):" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <TextBox Grid.Row="4" Name="txtDetail" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="5" Text="Ảnh bằng chứng (bắt buộc):" FontWeight="SemiBold" Margin="0,0,0,5"/>
        <Grid Grid.Row="6" Margin="0,0,0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal">
                <Button Content="Chọn ảnh" Width="90" Height="30" Click="BtnPickImages_Click"/>
                <Button Content="Xóa ảnh" Width="80" Height="30" Margin="10,0,0,0" Click="BtnRemoveImage_Click"/>
            </StackPanel>

            <ListBox Grid.Row="1"
                     x:Name="lstImages"
                     Margin="0,10,0,0"
                     Height="120"
                     BorderBrush="#FFE5E7EB"
                     BorderThickness="1"
                     Background="White"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,10,10"
                                Width="120"
                                Height="80"
                                Background="#FFF3F4F6"
                                CornerRadius="10"
                                ClipToBounds="True">
                            <Image Source="{Binding ., Converter={StaticResource ImageUrlToBitmapImageConverter}}"
                                   Stretch="UniformToFill" />
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Hủy" Width="80" Height="30" Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button Content="Gửi khiếu nại" Width="100" Height="30" Background="#EF4444" Foreground="White" Click="BtnSubmit_Click"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Window>
