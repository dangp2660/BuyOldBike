<Window x:Class="BuyOldBike_Presentation.Views.DeliveryAddressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Địa chỉ nghiệm thu"
        Width="560"
        Height="640"
        MinWidth="520"
        MinHeight="560"
        WindowStartupLocation="CenterOwner">
    <Border Background="#FFF9FAFB"
            Padding="22">
        <Border Background="White"
                BorderBrush="#FFE5E7EB"
                BorderThickness="1"
                CornerRadius="16"
                Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock FontSize="20"
                               FontWeight="Bold"
                               Text="Nhập địa chỉ để seller mang xe đến nghiệm thu" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#FF6B7280"
                               Text="Thông tin này sẽ được lưu cho đơn đặt cọc hiện tại." />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock FontSize="12" Foreground="#FF6B7280" Text="Họ tên người nhận (tuỳ chọn)" />
                        <TextBox Margin="0,8,0,0" Name="txtFullName" />

                        <TextBlock Margin="0,14,0,0" FontSize="12" Foreground="#FF6B7280" Text="Số điện thoại (tuỳ chọn)" />
                        <TextBox Margin="0,8,0,0" Name="txtPhoneNumber" />

                        <TextBlock Margin="0,14,0,0" FontSize="12" Foreground="#FF6B7280" Text="Tỉnh/Thành phố" />
                        <ComboBox Margin="0,8,0,0"
                                  Name="cbxProvince"
                                  IsEditable="False"
                                  DisplayMemberPath="Name"
                                  TextSearch.TextPath="Name"
                                  SelectionChanged="CbxProvince_SelectionChanged" />

                        <TextBlock Margin="0,14,0,0" FontSize="12" Foreground="#FF6B7280" Text="Quận/Huyện" />
                        <ComboBox Margin="0,8,0,0"
                                  Name="cbxDistrict"
                                  IsEditable="False"
                                  DisplayMemberPath="Name"
                                  TextSearch.TextPath="Name"
                                  IsEnabled="False"
                                  SelectionChanged="CbxDistrict_SelectionChanged" />

                        <TextBlock Margin="0,14,0,0" FontSize="12" Foreground="#FF6B7280" Text="Phường/Xã" />
                        <ComboBox Margin="0,8,0,0"
                                  Name="cbxWard"
                                  IsEditable="False"
                                  DisplayMemberPath="Name"
                                  TextSearch.TextPath="Name"
                                  IsEnabled="False" />

                        <TextBlock Margin="0,14,0,0" FontSize="12" Foreground="#FF6B7280" Text="Địa chỉ chi tiết" />
                        <TextBox Margin="0,8,0,0"
                                 Name="txtDetail"
                                 Height="96"
                                 Padding="10,8"
                                 VerticalContentAlignment="Top"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True" />
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2"
                            Margin="0,16,0,0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button MinWidth="110"
                            Height="36"
                            Padding="14,6"
                            Content="Huỷ"
                            Click="Cancel_Click" />
                    <Button Margin="10,0,0,0"
                            MinWidth="120"
                            Height="36"
                            Padding="14,6"
                            Content="Xác nhận"
                            Click="Confirm_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
