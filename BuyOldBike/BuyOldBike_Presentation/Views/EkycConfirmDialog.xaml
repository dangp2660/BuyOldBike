<Window x:Class="BuyOldBike_Presentation.Views.EkycConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Xác nhận thông tin eKYC"
        Width="560"
        Height="720"
        MinWidth="560"
        MinHeight="620"
        WindowStartupLocation="CenterOwner">
    <Border Background="#FFF9FAFB"
            Padding="22">
        <Border Background="White"
                BorderBrush="#FFE5E7EB"
                BorderThickness="1"
                CornerRadius="16"
                Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock FontSize="20"
                               FontWeight="Bold"
                               Text="Xác nhận thông tin eKYC" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#FF6B7280"
                               Text="Vui lòng kiểm tra và chỉnh sửa (nếu cần) trước khi gửi đăng ký." />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock FontSize="12" Foreground="#FF6B7280" Text="CCCD" />
                        <TextBox Margin="0,8,0,0" Name="txtIdNumber" />

                        <TextBlock Margin="0,14,0,0" FontSize="12" Foreground="#FF6B7280" Text="Họ tên" />
                        <TextBox Margin="0,8,0,0" Name="txtFullName" />

                        <TextBlock Margin="0,14,0,0" FontSize="12" Foreground="#FF6B7280" Text="Ngày sinh" />
                        <TextBox Margin="0,8,0,0" Name="txtDateOfBirth" />

                        <TextBlock Margin="0,14,0,0" FontSize="12" Foreground="#FF6B7280" Text="Giới tính" />
                        <TextBox Margin="0,8,0,0" Name="txtGender" />

                        <TextBlock Margin="0,14,0,0" FontSize="12" Foreground="#FF6B7280" Text="Quốc tịch" />
                        <TextBox Margin="0,8,0,0" Name="txtNationality" />

                        <TextBlock Margin="0,14,0,0" FontSize="12" Foreground="#FF6B7280" Text="Quê quán" />
                        <TextBox Margin="0,8,0,0" Name="txtPlaceOfOrigin" />

                        <TextBlock Margin="0,14,0,0" FontSize="12" Foreground="#FF6B7280" Text="Nơi thường trú" />
                        <TextBox Margin="0,8,0,0"
                                 Name="txtPlaceOfResidence"
                                 Height="96"
                                 Padding="10,8"
                                 VerticalContentAlignment="Top"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True" />

                        <TextBlock Margin="0,14,0,0" FontSize="12" Foreground="#FF6B7280" Text="Giá trị đến" />
                        <TextBox Margin="0,8,0,0" Name="txtExpiryDate" />
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2"
                            Margin="0,16,0,0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button MinWidth="110"
                            Height="36"
                            Padding="14,6"
                            Content="Huỷ"
                            Click="Cancel_Click" />
                    <Button Margin="10,0,0,0"
                            MinWidth="120"
                            Height="36"
                            Padding="14,6"
                            Content="Xác nhận"
                            Click="Confirm_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
