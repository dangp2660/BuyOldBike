<Window x:Class="BuyOldBike_Presentation.Views.InspectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:BuyOldBike_Presentation.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Khu vực Inspector"
        Width="1200"
        Height="800"
        MinWidth="1024"
        MinHeight="640"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:ImageUrlToBitmapImageConverter x:Key="ImageUrlToBitmapImageConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#FFE5E7EB"
                BorderThickness="0,0,0,1"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Inspector Center" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#FF6B7280"
                               Text="Thực hiện kiểm định và hỗ trợ xử lý tranh chấp" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Height="40" MinWidth="130" Content="Xem hồ sơ" />
                    <Button Margin="12,0,0,0" Height="40" MinWidth="130" Content="Đăng xuất" Click="BtnLogout_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="16" Background="{x:Null}" x:Name="tabInspector">
            <TabItem Header="Dashboard">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Tổng quan" />

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                <StackPanel>
                                    <TextBlock Foreground="#FF6B7280" Text="Pending Inspections" />
                                    <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Text="{Binding PendingInspectionCount}" />
                                    <TextBlock Margin="0,8,0,0" Foreground="#FF6B7280" Text="Đơn kiểm định đang chờ xử lý" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                <StackPanel>
                                    <TextBlock Foreground="#FF6B7280" Text="Completed Inspections" />
                                    <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Text="{Binding CompletedInspectionCountLast30Days}" />
                                    <TextBlock Margin="0,8,0,0" Foreground="#FF6B7280" Text="Đã hoàn tất trong 30 ngày" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                <StackPanel>
                                    <TextBlock Foreground="#FF6B7280" Text="Dispute Cases" />
                                    <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Text="{Binding PendingDisputeCount}" />
                                    <TextBlock Margin="0,8,0,0" Foreground="#FF6B7280" Text="Tranh chấp cần kết luận" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                <StackPanel>
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Danh sách chờ kiểm định" />
                                    <TextBlock Margin="0,4,0,0" Foreground="#FF6B7280" Text="Hiển thị các đơn mới nhất" />

                                    <DataGrid Margin="0,12,0,0"
                                              Height="240"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              CanUserResizeRows="False"
                                              CanUserReorderColumns="False"
                                              IsReadOnly="True"
                                              SelectionMode="Single"
                                              SelectionUnit="FullRow"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="None"
                                              RowHeaderWidth="0"
                                              BorderBrush="#FFE5E7EB"
                                              BorderThickness="1"
                                              Background="White"
                                              RowBackground="White"
                                              AlternatingRowBackground="#FFF9FAFB"
                                              x:Name="dgPendingInspections"
                                              SelectionChanged="dgPendingInspections_SelectionChanged">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Mã" Width="90" Binding="{Binding Listing.ListingId}" />
                                            <DataGridTextColumn Header="Xe" Width="210" Binding="{Binding Listing.Title}" />
                                            <DataGridTextColumn Header="Người bán" Width="160" Binding="{Binding Listing.Seller.Email}" />
                                            <DataGridTextColumn Header="Trạng thái" Width="120" Binding="{Binding Status}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                <StackPanel>
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Tranh chấp gần đây" />
                                    <TextBlock Margin="0,4,0,0" Foreground="#FF6B7280" Text="Các case đang mở" />

                                    <DataGrid Margin="0,12,0,0"
                                              Height="240"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              CanUserResizeRows="False"
                                              CanUserReorderColumns="False"
                                              IsReadOnly="True"
                                              SelectionMode="Single"
                                              SelectionUnit="FullRow"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="None"
                                              RowHeaderWidth="0"
                                              BorderBrush="#FFE5E7EB"
                                              BorderThickness="1"
                                              Background="White"
                                              RowBackground="White"
                                              AlternatingRowBackground="#FFF9FAFB"
                                              x:Name="dgRecentDisputes"
                                              SelectionChanged="dgRecentDisputes_SelectionChanged"
                                              ItemsSource="{Binding RecentDisputes}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Mã" Width="190" Binding="{Binding ReturnRequestId}" />
                                            <DataGridTextColumn Header="Xe" Width="200" Binding="{Binding Order.Listing.Title}" />
                                            <DataGridTextColumn Header="Lý do" Width="180" Binding="{Binding Reason}" />
                                            <DataGridTextColumn Header="Trạng thái" Width="120" Binding="{Binding Status}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Inspection" x:Name="tabInspection">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                        <StackPanel>
                            <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Danh sách chờ kiểm định" />
                            <TextBlock Margin="0,4,0,0" Foreground="#FF6B7280" Text="Chọn một listing để xem chi tiết và kiểm định" />

                            <DataGrid Margin="0,12,0,0"
                                      Height="640"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserResizeRows="False"
                                      CanUserReorderColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      RowHeaderWidth="0"
                                      BorderBrush="#FFE5E7EB"
                                      BorderThickness="1"
                                      Background="White"
                                      RowBackground="White"
                                      AlternatingRowBackground="#FFF9FAFB"
                                      x:Name="dgInspectionQueue"
                                      SelectionChanged="dgInspectionQueue_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Mã" Width="140" Binding="{Binding Listing.ListingId}" />
                                    <DataGridTextColumn Header="Xe" Width="140" Binding="{Binding Listing.Title}" />
                                    <DataGridTextColumn Header="Trạng thái" Width="80" Binding="{Binding Status}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <StackPanel x:Name="pnlInspectionDetails">
                            <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Thông tin xe" />
                            <TextBlock Margin="0,4,0,0" Foreground="#FF6B7280" Text="Chi tiết listing đang chọn" />

                            <Border Margin="0,12,0,0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Listing ID" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ListingId}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Tiêu đề" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Title}" />

                                    <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Người bán" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Seller.Email}" />

                                    <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Hãng / Loại" />
                                    <TextBlock Grid.Row="6" Grid.Column="1">
                                        <Run Text="{Binding Brand.BrandName}" />
                                        <Run Text=" • " />
                                        <Run Text="{Binding BikeType.Name}" />
                                    </TextBlock>

                                    <TextBlock Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Giá" />
                                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding Price, StringFormat={}{0:N0}đ}" />

                                    <TextBlock Grid.Row="10" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Số khung" />
                                    <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding FrameNumber}" />

                                    <TextBlock Grid.Row="12" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Sử dụng (tháng)" />
                                    <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding UsageDuration}" />

                                    <TextBlock Grid.Row="14" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Mô tả" />
                                    <TextBlock Grid.Row="14" Grid.Column="1" Text="{Binding Description}" TextWrapping="Wrap" />
                                </Grid>
                            </Border>

                            <Border Margin="0,16,0,0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                <StackPanel>
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Ảnh listing" />
                                    <ScrollViewer Margin="0,12,0,0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding ListingImages}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,10,0"
                                                            Width="120"
                                                            Height="80"
                                                            Background="#FFF3F4F6"
                                                            CornerRadius="10"
                                                            ClipToBounds="True">
                                                        <Image Source="{Binding ImageUrl, Converter={StaticResource ImageUrlToBitmapImageConverter}}"
                                                               Stretch="UniformToFill" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>

                            <TextBlock Margin="0,16,0,0" FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Inspection Checklist" />

                            <Border Margin="0,12,0,0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="260" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="12" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Frame System" />
                                    <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
                                        <RadioButton Margin="0,0,8,0" VerticalAlignment="Center" GroupName="FrameSystem" Content="Pass" IsChecked="True" x:Name="rbFramePass" />
                                        <RadioButton Margin="0,0,8,0" VerticalAlignment="Center" GroupName="FrameSystem" Content="Fail" />
                                    </StackPanel>

                                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Brake System" />
                                    <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal">
                                        <RadioButton Margin="0,0,8,0" VerticalAlignment="Center" GroupName="BrakeSystem" Content="Pass" IsChecked="True" x:Name="rbBrakePass" />
                                        <RadioButton Margin="0,0,8,0" VerticalAlignment="Center" GroupName="BrakeSystem" Content="Fail" />
                                    </StackPanel>

                                    <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Drivetrain" />
                                    <StackPanel Grid.Row="4" Grid.Column="2" Orientation="Horizontal">
                                        <RadioButton Margin="0,0,8,0" VerticalAlignment="Center" GroupName="Drivetrain" Content="Pass" IsChecked="True" x:Name="rbDrivetrainPass" />
                                        <RadioButton Margin="0,0,8,0" VerticalAlignment="Center" GroupName="Drivetrain" Content="Fail" />
                                    </StackPanel>

                                    <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Handlebar and Steering" />
                                    <StackPanel Grid.Row="6" Grid.Column="2" Orientation="Horizontal">
                                        <RadioButton Margin="0,0,8,0" VerticalAlignment="Center" GroupName="HandlebarSteering" Content="Pass" IsChecked="True" x:Name="rbHandlebarSteeringPass" />
                                        <RadioButton Margin="0,0,8,0" VerticalAlignment="Center" GroupName="HandlebarSteering" Content="Fail" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="380" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                    <StackPanel>
                                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Notes" />
                                        <TextBlock Margin="0,4,0,0" Foreground="#FF6B7280" Text="Ghi chú chi tiết cho báo cáo kiểm định" />

                                        <TextBox Margin="0,12,0,0"
                                                 x:Name="txtNotes"
                                                 Height="180"
                                                 Padding="10,8"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 VerticalContentAlignment="Top"
                                                 Text="" />

                                        <StackPanel Margin="0,12,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Margin="10,0,0,0" Content="Hoàn tất" x:Name="btnComplete" Click="btnComplete_Click" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                    <StackPanel>
                                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Upload Report" />
                                        <TextBlock Margin="0,4,0,0" Foreground="#FF6B7280" Text="Tải lên file PDF/ảnh báo cáo" />

                                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Ảnh báo cáo đã tải lên" />
                                        <ScrollViewer Margin="0,12,0,0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                            <ItemsControl x:Name="icInspectionReportImages">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,10,0"
                                                                Width="120"
                                                                Height="80"
                                                                Background="#FFF3F4F6"
                                                                CornerRadius="10"
                                                                ClipToBounds="True">
                                                            <Image Source="{Binding ImageUrl, Converter={StaticResource ImageUrlToBitmapImageConverter}}"
                                                                   Stretch="UniformToFill" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>

                                        <StackPanel Margin="0,14,0,0" Orientation="Horizontal">
                                            <Button x:Name="btnSelectInspectionReportImages" Content="Chọn ảnh" Click="BtnSelectInspectionReportImages_Click" />
                                            <Button x:Name="btnClearInspectionReportSelection" Margin="10,0,0,0" Content="Xóa chọn" Click="BtnClearInspectionReportSelection_Click" />
                                        </StackPanel>

                                        <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Ảnh chuẩn bị tải lên" />
                                        <ScrollViewer Margin="0,12,0,0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                            <ItemsControl x:Name="icInspectionSelectedReportPreviews">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,10,0"
                                                                Width="120"
                                                                Height="80"
                                                                Background="#FFF3F4F6"
                                                                CornerRadius="10"
                                                                ClipToBounds="True">
                                                            <Image Source="{Binding ., Converter={StaticResource ImageUrlToBitmapImageConverter}}"
                                                                   Stretch="UniformToFill" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="Dispute Support" x:Name="tabDisputeSupport">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="360" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                            <StackPanel>
                                <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Dispute List" />
                                <TextBlock Margin="0,4,0,0" Foreground="#FF6B7280" Text="Chọn một case để xem chi tiết" />

                                <TextBox Margin="0,12,0,0" Text="Tìm theo mã / xe / người mua..." />

                                <DataGrid Margin="0,12,0,0"
                                          Height="520"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserResizeRows="False"
                                          CanUserReorderColumns="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          SelectionUnit="FullRow"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="None"
                                          RowHeaderWidth="0"
                                          BorderBrush="#FFE5E7EB"
                                          BorderThickness="1"
                                          Background="White"
                                          RowBackground="White"
                                          AlternatingRowBackground="#FFF9FAFB"
                                          x:Name="dgDisputeList"
                                          SelectionChanged="dgDisputeList_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Đơn hàng" Width="140" Binding="{Binding Order.OrderId}" />
                                        <DataGridTextColumn Header="Lý do" Width="140" Binding="{Binding Reason}" />
                                        <DataGridTextColumn Header="Trạng thái" Width="80" Binding="{Binding Status}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Column="2" x:Name="pnlDisputeDetails">
                            <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Details Panel" />
                            <TextBlock Margin="0,4,0,0" Foreground="#FF6B7280" Text="Thông tin xe, khiếu nại và kết luận inspector" />

                            <Border Margin="0,12,0,0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="Bicycle Information" />
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Foreground="#FF6B7280" Text="Listing" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ListingTitle}" />
                                        <TextBlock Grid.Row="0" Grid.Column="3" Foreground="#FF6B7280" Text="Order" />
                                        <TextBlock Grid.Row="0" Grid.Column="4" Text="{Binding OrderId}" />

                                        <TextBlock Grid.Row="2" Grid.Column="0" Foreground="#FF6B7280" Text="Seller" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SellerName}" />
                                        <TextBlock Grid.Row="2" Grid.Column="3" Foreground="#FF6B7280" Text="Buyer" />
                                        <TextBlock Grid.Row="2" Grid.Column="4" Text="{Binding BuyerName}" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,16,0,0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="Kết quả kiểm định" />
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Foreground="#FF6B7280" Text="Result" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding InspectionResultText}" />
                                        <TextBlock Grid.Row="0" Grid.Column="3" Foreground="#FF6B7280" Text="Overall" />
                                        <TextBlock Grid.Row="0" Grid.Column="4" Text="{Binding InspectionOverallText}" />

                                        <TextBlock Grid.Row="2" Grid.Column="0" Foreground="#FF6B7280" Text="Note" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4" Text="{Binding InspectionNoteText}" TextWrapping="Wrap" />
                                    </Grid>

                                    <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding ComponentResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="260" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding ComponentName}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding ResultText}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="Chi tiết khiếu nại (Buyer)" />
                                        <TextBlock Margin="0,10,0,0"
                                                   TextWrapping="Wrap"
                                                   x:Name="txtDisputeDetail"
                                                   Text="Chọn một đơn để xem chi tiết" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="Ảnh bằng chứng (Buyer)" />
                                        <ScrollViewer Margin="0,12,0,0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                            <ItemsControl x:Name="icBuyerDisputeImages">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,10,0"
                                                                Width="120"
                                                                Height="80"
                                                                Background="#FFF3F4F6"
                                                                CornerRadius="10"
                                                                ClipToBounds="True">
                                                            <Image Source="{Binding ImageUrl, Converter={StaticResource ImageUrlToBitmapImageConverter}}"
                                                                   Stretch="UniformToFill" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>

                                        <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Ảnh kiểm định (Inspector)" />
                                        <ScrollViewer Margin="0,12,0,0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                            <ItemsControl x:Name="icInspectorDisputeImages">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,10,0"
                                                                Width="120"
                                                                Height="80"
                                                                Background="#FFF3F4F6"
                                                                CornerRadius="10"
                                                                ClipToBounds="True">
                                                            <Image Source="{Binding ImageUrl, Converter={StaticResource ImageUrlToBitmapImageConverter}}"
                                                                   Stretch="UniformToFill" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>

                                        <TextBlock Margin="0,14,0,0" FontWeight="SemiBold" Text="Ghi chú kiểm định (Inspector)" />
                                        <Border Margin="0,8,0,0" Background="#FFF9FAFB" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="10" Padding="10">
                                            <TextBlock Text="{Binding InspectionNoteText}" TextWrapping="Wrap" />
                                        </Border>

                                        <StackPanel Margin="0,14,0,0" Orientation="Horizontal">
                                            <Button x:Name="btnSelectInspectorImages" Content="Chọn ảnh" Click="BtnSelectInspectorImages_Click" />
                                            <Button x:Name="btnUploadInspectorImages" Margin="10,0,0,0" Content="Tải lên" Click="BtnUploadInspectorImages_Click" />
                                            <Button x:Name="btnClearInspectorImages" Margin="10,0,0,0" Content="Xóa chọn" Click="BtnClearInspectorSelection_Click" />
                                        </StackPanel>

                                        <ScrollViewer Margin="0,12,0,0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                            <ItemsControl x:Name="icInspectorSelectedPreviews">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,10,0"
                                                                Width="120"
                                                                Height="80"
                                                                Background="#FFF3F4F6"
                                                                CornerRadius="10"
                                                                ClipToBounds="True">
                                                            <Image Source="{Binding ., Converter={StaticResource ImageUrlToBitmapImageConverter}}"
                                                                   Stretch="UniformToFill" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Margin="0,16,0,0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="Quyết định hoàn tiền" />
                                    <TextBlock Margin="0,4,0,0" Foreground="#FF6B7280" Text="Kéo thanh trượt để chọn phần trăm hoàn lại tiền cọc cho người mua" />
                                    
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <Slider x:Name="sldRefundPercentage" 
                                                Width="200" 
                                                Minimum="0" 
                                                Maximum="100" 
                                                Value="100" 
                                                TickFrequency="5" 
                                                IsSnapToTickEnabled="True" 
                                                VerticalAlignment="Center"/>
                                        <TextBlock Margin="10,0,0,0" 
                                                   Text="{Binding ElementName=sldRefundPercentage, Path=Value, StringFormat={}{0}%}" 
                                                   VerticalAlignment="Center" 
                                                   FontWeight="Bold"/>
                                    </StackPanel>

                                    <StackPanel Margin="0,12,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Margin="10,0,0,0" Content="Chốt kết luận" Click="BtnResolveDispute_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
