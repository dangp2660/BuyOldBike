<Window x:Class="BuyOldBike_Presentation.Views.InspectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Khu vực Inspector"
        Width="1200"
        Height="800"
        MinWidth="1024"
        MinHeight="640"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF111827" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SubtleTextBrush}" />
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="6,0,0,0" />
        </Style>

        <Style x:Key="InlineLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#FF111827" />
        </Style>

        <Style x:Key="SmallRadioStyle" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DataGridBaseStyle" TargetType="{x:Type DataGrid}">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserReorderColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
            <Setter Property="RowBackground" Value="White" />
            <Setter Property="AlternatingRowBackground" Value="#FFF9FAFB" />
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="#FFF3F4F6" />
            <Setter Property="Foreground" Value="#FF111827" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style TargetType="{x:Type DataGridCell}">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <XmlDataProvider x:Key="PendingInspectionsProvider" XPath="/Items/Item">
            <x:XData>
                <Items xmlns="">
                    <Item Code="INSP-00012" Bike="Giant TCR 2021" Seller="Nguyễn A" Appointment="10:30 14/03" Status="Pending" />
                    <Item Code="INSP-00013" Bike="Trek Emonda" Seller="Trần B" Appointment="15:00 16/03" Status="Pending" />
                    <Item Code="INSP-00014" Bike="Specialized Allez" Seller="Lê C" Appointment="09:00 18/03" Status="Pending" />
                </Items>
            </x:XData>
        </XmlDataProvider>

        <XmlDataProvider x:Key="RecentDisputesProvider" XPath="/Items/Item">
            <x:XData>
                <Items xmlns="">
                    <Item Code="DSP-00007" Bike="Giant Defy" Severity="High" Status="Open" />
                    <Item Code="DSP-00008" Bike="Trek Domane" Severity="Medium" Status="Open" />
                </Items>
            </x:XData>
        </XmlDataProvider>

        <XmlDataProvider x:Key="DisputeListProvider" XPath="/Items/Item">
            <x:XData>
                <Items xmlns="">
                    <Item Code="DSP-00007" Bike="Giant Defy" Status="Open" />
                    <Item Code="DSP-00008" Bike="Trek Domane" Status="Open" />
                    <Item Code="DSP-00009" Bike="Specialized Roubaix" Status="Closed" />
                </Items>
            </x:XData>
        </XmlDataProvider>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Inspector Center" />
                    <TextBlock Margin="0,4,0,0"
                               Style="{StaticResource MutedTextStyle}"
                               Text="Thực hiện kiểm định và hỗ trợ xử lý tranh chấp" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButtonStyle}" Height="40" MinWidth="130" Content="Xem hồ sơ" />
                    <Button Margin="12,0,0,0" Height="40" MinWidth="130" Content="Đăng xuất" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="16" Background="{x:Null}">
            <TabItem Header="Dashboard">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Tổng quan" />

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="Pending Inspections" />
                                    <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Text="5" />
                                    <TextBlock Margin="0,8,0,0" Style="{StaticResource MutedTextStyle}" Text="Đơn kiểm định đang chờ xử lý" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="Completed Inspections" />
                                    <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Text="18" />
                                    <TextBlock Margin="0,8,0,0" Style="{StaticResource MutedTextStyle}" Text="Đã hoàn tất trong 30 ngày" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4" Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="Dispute Cases" />
                                    <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Text="2" />
                                    <TextBlock Margin="0,8,0,0" Style="{StaticResource MutedTextStyle}" Text="Tranh chấp cần kết luận" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Danh sách chờ kiểm định" />
                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource MutedTextStyle}" Text="Hiển thị các đơn mới nhất" />

                                    <DataGrid Margin="0,12,0,0"
                                              Height="240"
                                              Style="{StaticResource DataGridBaseStyle}"
                                              ItemsSource="{Binding Source={StaticResource PendingInspectionsProvider}}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Mã" Width="90" Binding="{Binding XPath=@Code}" />
                                            <DataGridTextColumn Header="Xe" Width="210" Binding="{Binding XPath=@Bike}" />
                                            <DataGridTextColumn Header="Người bán" Width="160" Binding="{Binding XPath=@Seller}" />
                                            <DataGridTextColumn Header="Hẹn lịch" Width="140" Binding="{Binding XPath=@Appointment}" />
                                            <DataGridTextColumn Header="Trạng thái" Width="120" Binding="{Binding XPath=@Status}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Tranh chấp gần đây" />
                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource MutedTextStyle}" Text="Các case đang mở" />

                                    <DataGrid Margin="0,12,0,0"
                                              Height="240"
                                              Style="{StaticResource DataGridBaseStyle}"
                                              ItemsSource="{Binding Source={StaticResource RecentDisputesProvider}}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Mã" Width="90" Binding="{Binding XPath=@Code}" />
                                            <DataGridTextColumn Header="Xe" Width="220" Binding="{Binding XPath=@Bike}" />
                                            <DataGridTextColumn Header="Mức độ" Width="110" Binding="{Binding XPath=@Severity}" />
                                            <DataGridTextColumn Header="Trạng thái" Width="120" Binding="{Binding XPath=@Status}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Inspection">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Inspection Checklist" />

                        <Border Margin="0,12,0,0" Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource InlineLabelStyle}" Text="Frame Condition" />
                                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
                                    <RadioButton Style="{StaticResource SmallRadioStyle}" GroupName="FrameCondition" Content="Pass" IsChecked="True" />
                                    <RadioButton Style="{StaticResource SmallRadioStyle}" GroupName="FrameCondition" Content="Fail" />
                                </StackPanel>

                                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource InlineLabelStyle}" Text="Brake System" />
                                <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal">
                                    <RadioButton Style="{StaticResource SmallRadioStyle}" GroupName="BrakeSystem" Content="Pass" IsChecked="True" />
                                    <RadioButton Style="{StaticResource SmallRadioStyle}" GroupName="BrakeSystem" Content="Fail" />
                                </StackPanel>

                                <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource InlineLabelStyle}" Text="Drivetrain" />
                                <StackPanel Grid.Row="4" Grid.Column="2" Orientation="Horizontal">
                                    <RadioButton Style="{StaticResource SmallRadioStyle}" GroupName="Drivetrain" Content="Pass" IsChecked="True" />
                                    <RadioButton Style="{StaticResource SmallRadioStyle}" GroupName="Drivetrain" Content="Fail" />
                                </StackPanel>

                                <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource InlineLabelStyle}" Text="Wheel Alignment" />
                                <StackPanel Grid.Row="6" Grid.Column="2" Orientation="Horizontal">
                                    <RadioButton Style="{StaticResource SmallRadioStyle}" GroupName="WheelAlignment" Content="Pass" IsChecked="True" />
                                    <RadioButton Style="{StaticResource SmallRadioStyle}" GroupName="WheelAlignment" Content="Fail" />
                                </StackPanel>

                                <TextBlock Grid.Row="8" Grid.Column="0" Style="{StaticResource InlineLabelStyle}" Text="Suspension" />
                                <StackPanel Grid.Row="8" Grid.Column="2" Orientation="Horizontal">
                                    <RadioButton Style="{StaticResource SmallRadioStyle}" GroupName="Suspension" Content="Pass" IsChecked="True" />
                                    <RadioButton Style="{StaticResource SmallRadioStyle}" GroupName="Suspension" Content="Fail" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="380" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Notes" />
                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource MutedTextStyle}" Text="Ghi chú chi tiết cho báo cáo kiểm định" />

                                    <TextBox Margin="0,12,0,0"
                                             Height="180"
                                             Padding="10,8"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalContentAlignment="Top"
                                             Text="Tình trạng tổng thể tốt. Phanh cần căn chỉnh nhẹ. Vỏ bánh mòn ~30%." />

                                    <StackPanel Margin="0,12,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="Lưu nháp" />
                                        <Button Margin="10,0,0,0" Content="Hoàn tất" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Upload Report" />
                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource MutedTextStyle}" Text="Tải lên file PDF/ảnh báo cáo" />

                                    <Border Margin="0,12,0,0"
                                            Height="140"
                                            Background="#FFF3F4F6"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="12">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock FontWeight="SemiBold" Text="Kéo thả file vào đây" />
                                            <TextBlock Margin="0,4,0,0" Style="{StaticResource MutedTextStyle}" Text="Hoặc bấm để chọn file" />
                                            <Button Margin="0,10,0,0" Style="{StaticResource SecondaryButtonStyle}" Content="Chọn file" />
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Margin="0,12,0,0" Style="{StaticResource MutedTextStyle}" Text="Tệp đã chọn" />
                                    <ListBox Margin="0,6,0,0" Height="120">
                                        <ListBoxItem Content="inspection_report_INSP-00012.pdf" />
                                        <ListBoxItem Content="brake_closeup.jpg" />
                                    </ListBox>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Dispute Support">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="360" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Dispute List" />
                                <TextBlock Margin="0,4,0,0" Style="{StaticResource MutedTextStyle}" Text="Chọn một case để xem chi tiết" />

                                <TextBox Margin="0,12,0,0" Text="Tìm theo mã / xe / người mua..." />

                                <DataGrid Margin="0,12,0,0"
                                          Height="520"
                                          Style="{StaticResource DataGridBaseStyle}"
                                          ItemsSource="{Binding Source={StaticResource DisputeListProvider}}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Mã" Width="90" Binding="{Binding XPath=@Code}" />
                                        <DataGridTextColumn Header="Xe" Width="180" Binding="{Binding XPath=@Bike}" />
                                        <DataGridTextColumn Header="Trạng thái" Width="80" Binding="{Binding XPath=@Status}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Details Panel" />
                            <TextBlock Margin="0,4,0,0" Style="{StaticResource MutedTextStyle}" Text="Thông tin xe, khiếu nại và kết luận inspector" />

                            <Border Margin="0,12,0,0" Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="Bicycle Information" />
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="8" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource MutedTextStyle}" Text="Listing" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Giant Defy Advanced 2 (2020)" />
                                        <TextBlock Grid.Row="0" Grid.Column="3" Style="{StaticResource MutedTextStyle}" Text="Transaction" />
                                        <TextBlock Grid.Row="0" Grid.Column="4" Text="TX-00421" />

                                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource MutedTextStyle}" Text="Seller" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="Nguyễn A" />
                                        <TextBlock Grid.Row="2" Grid.Column="3" Style="{StaticResource MutedTextStyle}" Text="Buyer" />
                                        <TextBlock Grid.Row="2" Grid.Column="4" Text="Trần B" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="Buyer Complaint" />
                                        <TextBlock Margin="0,10,0,0"
                                                   TextWrapping="Wrap"
                                                   Text="Người mua phản ánh phanh sau bị trượt, không đúng mô tả. Có dấu hiệu va đập nhẹ ở gióng." />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="Seller Response" />
                                        <TextBlock Margin="0,10,0,0"
                                                   TextWrapping="Wrap"
                                                   Text="Người bán cho biết xe được bảo dưỡng trước khi giao, có thể do vận chuyển làm lệch phanh." />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Margin="0,16,0,0" Style="{StaticResource CardBorderStyle}">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="Inspector Conclusion" />
                                    <TextBlock Margin="0,4,0,0" Style="{StaticResource MutedTextStyle}" Text="Ghi kết luận và đề xuất xử lý" />

                                    <TextBox Margin="0,12,0,0"
                                             Height="140"
                                             Padding="10,8"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalContentAlignment="Top"
                                             Text="Kiểm tra thực tế: phanh sau cần căn chỉnh, không có vết nứt khung. Đề xuất hỗ trợ phí bảo dưỡng phanh, giao dịch tiếp tục." />

                                    <StackPanel Margin="0,12,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="Yêu cầu thêm bằng chứng" />
                                        <Button Margin="10,0,0,0" Content="Chốt kết luận" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
