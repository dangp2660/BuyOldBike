<Window x:Class="BuyOldBike_Presentation.Views.ListingDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Chi tiết bài đăng"
        Width="900"
        Height="720"
        MinWidth="760"
        MinHeight="600"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#FFE5E7EB"
                BorderThickness="0,0,0,1"
                Padding="16">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Listing Detail" />
                <TextBlock Margin="0,4,0,0" Foreground="#FF6B7280" Text="Xem chi tiết bài đăng vừa tạo" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="16" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Thông tin xe" />
                <TextBlock Margin="0,4,0,0" Foreground="#FF6B7280" Text="Chi tiết listing" />

                <Border Margin="0,12,0,0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Listing ID -->
                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Listing ID" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding ListingBike.ListingId}" />

                        <!-- Status -->
                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Trạng thái" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding ListingBike.Status}" />

                        <!-- Title -->
                        <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Tiêu đề" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" x:Name="tbTitle" Text="{Binding ListingBike.Title}" />
                        <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" x:Name="txtTitle_Edit" Visibility="Collapsed" Height="24" Margin="0,2,0,2"/>

                        <!-- Brand / Type -->
                        <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Hãng / Loại" />
                        <TextBlock Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" x:Name="tbBrandType">
                            <Run Text="{Binding ListingBike.Brand.BrandName}" />
                            <Run Text=" • " />
                            <Run Text="{Binding ListingBike.BikeType.Name}" />
                        </TextBlock>
                        <ComboBox Grid.Row="6" Grid.Column="1" x:Name="cbxBrand_Edit" Visibility="Collapsed" Margin="0,2,2,2" Height="24"/>
                        <ComboBox Grid.Row="6" Grid.Column="2" x:Name="cbxType_Edit" Visibility="Collapsed" Margin="2,2,0,2" Height="24"/>

                        <!-- Price -->
                        <TextBlock Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Giá" />
                        <TextBlock Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2" x:Name="tbPrice" Text="{Binding ListingBike.Price, StringFormat={}{0:N0}đ}" />
                        <TextBox Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2" x:Name="txtPrice_Edit" Visibility="Collapsed" Height="24" Margin="0,2,0,2" PreviewTextInput="txtPrice_Edit_PreviewTextInput" TextChanged="txtPrice_Edit_TextChanged"/>

                        <!-- Frame Number -->
                        <TextBlock Grid.Row="10" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Số khung" />
                        <TextBlock Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="2" x:Name="tbFrame" Text="{Binding ListingBike.FrameNumber}" />
                        <TextBox Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="2" x:Name="txtFrame_Edit" Visibility="Collapsed" Height="24" Margin="0,2,0,2"/>

                        <!-- Usage Duration -->
                        <TextBlock Grid.Row="12" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Sử dụng (tháng)" />
                        <TextBlock Grid.Row="12" Grid.Column="1" Grid.ColumnSpan="2" x:Name="tbUsage" Text="{Binding ListingBike.UsageDuration}" />
                        <TextBox Grid.Row="12" Grid.Column="1" Grid.ColumnSpan="2" x:Name="txtUsage_Edit" Visibility="Collapsed" Height="24" Margin="0,2,0,2"/>

                        <!-- Description -->
                        <TextBlock Grid.Row="14" Grid.Column="0" VerticalAlignment="Top" Foreground="#FF111827" Text="Mô tả" />
                        <TextBlock Grid.Row="14" Grid.Column="1" Grid.ColumnSpan="2" x:Name="tbDesc" Text="{Binding ListingBike.Description}" TextWrapping="Wrap" MinHeight="80"/>
                        <TextBox Grid.Row="14" Grid.Column="1" Grid.ColumnSpan="2" x:Name="txtDesc_Edit" Visibility="Collapsed" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80" Margin="0,2,0,2"/>
                    </Grid>
                </Border>

                <Border Margin="0,16,0,0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Ảnh listing" />
                        <Button x:Name="btnAddImage" Content="Thêm ảnh" Width="120" Height="30" Margin="0,8,0,0" Visibility="Collapsed" Click="BtnAddImage_Click" />
                        <ScrollViewer Margin="0,12,0,0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding Images}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,10,0"
                                                Width="160"
                                                Height="110"
                                                Background="#FFF3F4F6"
                                                CornerRadius="10"
                                                ClipToBounds="True">
                                            <Image Source="{Binding}" Stretch="UniformToFill" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <Border x:Name="ChatPanel"
                                Margin="0,16,0,0"
                                Background="White"
                                BorderBrush="#FFE5E7EB"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock FontSize="16" FontWeight="SemiBold"
                                       Foreground="#FF111827" Text="Chat với Seller"/>
                                <!-- Danh sách tin nhắn -->
                                <ScrollViewer x:Name="ChatScrollViewer"
                                          Height="280"
                                          Margin="0,12,0,0"
                                          VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="IcMessages"
                                          ItemsSource="{Binding Messages,
                                          ElementName=ChatPanelControl}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,4,0,4">
                                                    <!-- Tin nhắn của mình — căn phải -->
                                                    <Border x:Name="Bubble"
                                                            MaxWidth="420"
                                                            Padding="10,8"
                                                            Background="#FF3B82F6"
                                                            CornerRadius="12,12,0,12">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <!-- mặc định: tin nhắn của mình -->
                                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                                <Style.Triggers>
                                                                    <!-- tin nhắn người khác -->
                                                                    <DataTrigger Binding="{Binding IsMine}" Value="False">
                                                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                                                        <Setter Property="Background" Value="#FFF3F4F6"/>
                                                                        <Setter Property="CornerRadius" Value="12,12,12,0"/>
                                                                    </DataTrigger>

                                                                </Style.Triggers>

                                                            </Style>
                                                        </Border.Style>

                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Content}"
                                                                       TextWrapping="Wrap">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsMine}" Value="False">
                                                                                <Setter Property="Foreground" Value="#FF111827"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding SentAt, StringFormat={}{0:HH:mm dd/MM}}"
                                                                       FontSize="10"
                                                                       HorizontalAlignment="Right"
                                                                       Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- Input -->
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#FFE5E7EB"
                BorderThickness="1,0,0,0"
                Padding="16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnContact"
                        Height="40" MinWidth="120"
                        Margin="0,0,10,0"
                        Content="💬 Liên hệ Seller"
                        Click="BtnContact_Click"
                        Visibility="Collapsed"/>
                <Button Height="40" MinWidth="120" Margin="0,0,10,0" Content="Đóng" Click="BtnClose_Click" />
                <Button Height="40" MinWidth="120" Margin="0,0,10,0" Content="Lưu" Click="BtnSave_Click" x:Name="btnSave" Visibility="Collapsed" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
