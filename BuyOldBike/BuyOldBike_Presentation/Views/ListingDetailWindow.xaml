<Window x:Class="BuyOldBike_Presentation.Views.ListingDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Chi tiết bài đăng"
        Width="900"
        Height="720"
        MinWidth="760"
        MinHeight="600"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#FFE5E7EB"
                BorderThickness="0,0,0,1"
                Padding="16">
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Listing Detail" />
                <TextBlock Margin="0,4,0,0" Foreground="#FF6B7280" Text="Xem chi tiết bài đăng vừa tạo" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="16" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Thông tin xe" />
                <TextBlock Margin="0,4,0,0" Foreground="#FF6B7280" Text="Chi tiết listing" />

                <Border Margin="0,12,0,0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Listing ID" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ListingBike.ListingId}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Trạng thái" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ListingBike.Status}" />

                        <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Tiêu đề" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ListingBike.Title}" />

                        <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Người bán" />
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding ListingBike.Seller.Email}" />

                        <TextBlock Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Hãng / Loại" />
                        <TextBlock Grid.Row="8" Grid.Column="1">
                            <Run Text="{Binding ListingBike.Brand.BrandName}" />
                            <Run Text=" • " />
                            <Run Text="{Binding ListingBike.BikeType.Name}" />
                        </TextBlock>

                        <TextBlock Grid.Row="10" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Giá" />
                        <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding ListingBike.Price, StringFormat={}{0:N0}đ}" />

                        <TextBlock Grid.Row="12" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Số khung" />
                        <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding ListingBike.FrameNumber}" />

                        <TextBlock Grid.Row="14" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Sử dụng (tháng)" />
                        <TextBlock Grid.Row="14" Grid.Column="1" Text="{Binding ListingBike.UsageDuration}" />

                        <TextBlock Grid.Row="16" Grid.Column="0" VerticalAlignment="Center" Foreground="#FF111827" Text="Mô tả" />
                        <TextBlock Grid.Row="16" Grid.Column="1" Text="{Binding ListingBike.Description}" TextWrapping="Wrap" />
                    </Grid>
                </Border>

                <Border Margin="0,16,0,0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Ảnh listing" />
                        <ScrollViewer Margin="0,12,0,0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding Images}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,10,0"
                                                Width="160"
                                                Height="110"
                                                Background="#FFF3F4F6"
                                                CornerRadius="10"
                                                ClipToBounds="True">
                                            <Image Source="{Binding}" Stretch="UniformToFill" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#FFE5E7EB"
                BorderThickness="1,0,0,0"
                Padding="16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Height="40" MinWidth="120" Margin="0,0,10,0" Content="Đặt mua" />
                <Button Height="40" MinWidth="120" Content="Đóng" Click="BtnClose_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
