<Window x:Class="BuyOldBike_Presentation.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Đăng nhập"
        WindowState="Maximized">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="16"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center"
                        MaxWidth="420"
                        Margin="0,40,0,0">
                <TextBlock FontSize="28"
                           FontWeight="Bold"
                           Text="BuyOldBike" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{StaticResource SubtleTextBrush}"
                           Text="Đăng nhập để tiếp tục" />

                <Border Margin="0,22,0,0"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="22">
                    <StackPanel>
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Đăng nhập" />

                        <TextBlock Margin="0,16,0,6"
                                   FontSize="12"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   Text="Email" />
                        <TextBox Height="40"
                                 FontSize="14"
                                 Name="txtEmail"
                                 />

                        <TextBlock Margin="0,14,0,6"
                                   FontSize="12"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   Text="Mật khẩu" />
                        <PasswordBox Height="40"
                                     FontSize="14"
                                     Name="txtPassword"
                                     />

                        <Button Margin="0,18,0,0"
                                Height="42"
                                FontSize="14"
                                Content="Đăng nhập"
                                Name="btnLogin" Click="btnLogin_Click"/>

                        <TextBlock Margin="0,14,0,0"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource SubtleTextBrush}">
                            <Run Text="Chưa có tài khoản? " />
                            <Run Text="Đăng ký"
                                 TextDecorations="Underline"
                                 Foreground="{StaticResource PrimaryBrush}" />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
