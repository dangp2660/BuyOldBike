<Window x:Class="BuyOldBike_Presentation.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Đăng nhập"
        Width="1200"
        Height="800"    
        MinWidth="1024"
        MinHeight="640"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#FFF9FAFB">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="460" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#FF2563EB"
                Padding="44">
            <StackPanel VerticalAlignment="Center">
                <TextBlock FontSize="34"
                           FontWeight="Bold"
                           Foreground="White"
                           Text="BuyOldBike" />
                <TextBlock Margin="0,10,0,0"
                           FontSize="14"
                           Foreground="#FFE5E7EB"
                           Text="Mua bán xe đạp cũ an toàn, minh bạch." />
                <Border Margin="0,26,0,0"
                        Background="#FF1D4ED8"
                        CornerRadius="14"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Foreground="White"
                                   FontWeight="SemiBold"
                                   Text="Gợi ý" />
                        <TextBlock Margin="0,10,0,0"
                                   Foreground="#FFE5E7EB"
                                   Text="Đăng nhập để xem danh sách xe và quản lý đơn hàng." />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      Padding="46">
            <StackPanel HorizontalAlignment="Center"
                        MaxWidth="460"
                        Margin="0,20,0,0">
                <TextBlock FontSize="24"
                           FontWeight="Bold"
                           Text="Đăng nhập" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="#FF6B7280"
                           Text="Nhập thông tin tài khoản để tiếp tục" />

                <Border Margin="0,22,0,0"
                        Background="White"
                        BorderBrush="#FFE5E7EB"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="24">
                    <StackPanel>
                        <TextBlock FontSize="12"
                                   Foreground="#FF6B7280"
                                   Text="Email" />
                        <TextBox Margin="0,8,0,0"
                                 Height="40"
                                 FontSize="14"
                                 Name="txtEmail" />

                        <TextBlock Margin="0,16,0,0"
                                   FontSize="12"
                                   Foreground="#FF6B7280"
                                   Text="Mật khẩu" />
                        <PasswordBox Margin="0,8,0,0"
                                     Height="40"
                                     FontSize="14"
                                     Name="txtPassword" />

                        <Button Margin="0,18,0,0"
                                Height="44"
                                FontSize="14"
                                Content="Đăng nhập"
                                Name="btnLogin"
                                Click="btnLogin_Click" />

                        <TextBlock Margin="0,14,0,0"
                                   HorizontalAlignment="Center"
                                   Foreground="#FF6B7280">
                            <Run Text="Chưa có tài khoản? " />
                            <Hyperlink Click="OpenRegister_Click"
                                       Foreground="#FF2563EB"
                                       TextDecorations="Underline">
                                <Run Text="Đăng ký" />
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
