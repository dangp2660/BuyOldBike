<Window x:Class="BuyOldBike_Presentation.Views.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Hồ sơ eKYC"
        Width="960"
        Height="720"
        MinWidth="760"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="24">
        <StackPanel>
            <TextBlock FontSize="24"
                       FontWeight="Bold"
                       Text="Hồ sơ eKYC" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{StaticResource SubtleTextBrush}"
                       Name="txtStatus"
                       Text="Đang tải dữ liệu..." />

            <Border Margin="0,18,0,0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="18">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="Tài khoản" />
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Foreground="{StaticResource SubtleTextBrush}" Text="Email" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Name="txtEmail" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,0" Foreground="{StaticResource SubtleTextBrush}" Text="Số điện thoại" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Name="txtPhone" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,0" Foreground="{StaticResource SubtleTextBrush}" Text="Vai trò" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Name="txtRole" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Margin="0,14,0,0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="18"
                    Name="kycInfoSection">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="Thông tin CCCD (eKYC)" />
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Foreground="{StaticResource SubtleTextBrush}" Text="Số CCCD" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Name="txtIdNumber" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,0" Foreground="{StaticResource SubtleTextBrush}" Text="Họ và tên" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Name="txtFullName" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,0" Foreground="{StaticResource SubtleTextBrush}" Text="Ngày sinh" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Name="txtDob" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,10,0,0" Foreground="{StaticResource SubtleTextBrush}" Text="Giới tính" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" Name="txtGender" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,10,0,0" Foreground="{StaticResource SubtleTextBrush}" Text="Quốc tịch" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,10,0,0" Name="txtNationality" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,10,0,0" Foreground="{StaticResource SubtleTextBrush}" Text="Quê quán" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,10,0,0" Name="txtOrigin" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,10,0,0" Foreground="{StaticResource SubtleTextBrush}" Text="Thường trú" />
                        <TextBlock Grid.Row="6" Grid.Column="1" Margin="0,10,0,0" Name="txtResidence" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,10,0,0" Foreground="{StaticResource SubtleTextBrush}" Text="Hạn sử dụng" />
                        <TextBlock Grid.Row="7" Grid.Column="1" Margin="0,10,0,0" Name="txtExpiry" />

                        <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,10,0,0" Foreground="{StaticResource SubtleTextBrush}" Text="Xác thực lúc" />
                        <TextBlock Grid.Row="8" Grid.Column="1" Margin="0,10,0,0" Name="txtVerifiedAt" />
                    </Grid>
                </StackPanel>
            </Border>

            <Button Margin="0,18,0,0"
                    HorizontalAlignment="Right"
                    Width="120"
                    Height="40"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Content="Đóng"
                    Click="Close_Click" />
        </StackPanel>
    </ScrollViewer>
</Window>
