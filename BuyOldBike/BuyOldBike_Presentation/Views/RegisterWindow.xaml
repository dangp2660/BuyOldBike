<Window x:Class="BuyOldBike_Presentation.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Đăng ký"
        Width="1200"
        Height="800"
        MinWidth="1024"
        MinHeight="640"
        WindowStartupLocation="CenterScreen">
    <Border Background="{StaticResource AppBackgroundBrush}">
        <DockPanel LastChildFill="True">
            <Border DockPanel.Dock="Left"
                    Width="460"
                    Background="{StaticResource PrimaryBrush}"
                    Padding="44">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="34"
                               FontWeight="Bold"
                               Foreground="White"
                               Text="BuyOldBike" />
                    <TextBlock Margin="0,10,0,0"
                               FontSize="14"
                               Foreground="#E5E7EB"
                               Text="Đăng ký nhanh và bắt đầu giao dịch." />
                    <Border Margin="0,26,0,0"
                            Background="#1D4ED8"
                            CornerRadius="14"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Foreground="White"
                                       FontWeight="SemiBold"
                                       Text="Lưu ý" />
                            <TextBlock Margin="0,10,0,0"
                                       Foreground="#E5E7EB"
                                       Text="Bảo mật thông tin đăng nhập và không chia sẻ mật khẩu với người khác." />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="46">
                <StackPanel HorizontalAlignment="Center"
                            MaxWidth="460"
                            Margin="0,20,0,0">
                    <TextBlock FontSize="24"
                               FontWeight="Bold"
                               Text="Đăng ký" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource SubtleTextBrush}"
                               Text="Tạo tài khoản mới để bắt đầu" />

                    <Border Margin="0,22,0,0"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="24">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.12" />
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock FontSize="12"
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       Text="Email" />
                            <TextBox Margin="0,8,0,0"
                                     Height="40"
                                     FontSize="14"
                                     Name="txtEmail" />

                            <TextBlock Margin="0,16,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       Text="Số điện thoại" />
                            <TextBox Margin="0,8,0,0"
                                     Height="40"
                                     FontSize="14"
                                     Name="txtPhone" />

                            <TextBlock Margin="0,16,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       Text="Mật khẩu" />
                            <PasswordBox Margin="0,8,0,0"
                                         Height="40"
                                         FontSize="14"
                                         Name="txtPassword" />

                            <TextBlock Margin="0,16,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource SubtleTextBrush}"
                                       Text="Nhập lại mật khẩu" />
                            <PasswordBox Margin="0,8,0,0"
                                         Height="40"
                                         FontSize="14"
                                         Name="txtConfirmPassword" />

                            <Border Margin="0,18,0,0"
                                    Background="#FFF9FAFB"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="14">
                                <Expander Header="eKYC (Xác thực danh tính)" IsExpanded="False">
                                    <StackPanel Margin="0,10,0,0">
                                        <TextBlock Foreground="{StaticResource SubtleTextBrush}"
                                                   FontSize="12"
                                                   Text="Chọn 3 ảnh (CCCD mặt trước, mặt sau, selfie)." />

                                        <StackPanel Margin="0,12,0,0">
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Left"
                                                           VerticalAlignment="Center"
                                                           Text="CCCD mặt trước" />
                                                <Button DockPanel.Dock="Right"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Height="30"
                                                        Padding="10,4"
                                                        Content="Chọn ảnh"
                                                        Name="btnFrontImge"
                                                        Click="btnFrontImge_Click" />
                                            </DockPanel>

                                            <DockPanel Margin="0,10,0,0">
                                                <TextBlock DockPanel.Dock="Left"
                                                           VerticalAlignment="Center"
                                                           Text="CCCD mặt sau" />
                                                <Button DockPanel.Dock="Right"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Height="30"
                                                        Padding="10,4"
                                                        Content="Chọn ảnh"
                                                        Name="btnBackImg"
                                                        Click="btnBackImg_Click" />
                                            </DockPanel>

                                            <DockPanel Margin="0,10,0,0">
                                                <TextBlock DockPanel.Dock="Left"
                                                           VerticalAlignment="Center"
                                                           Text="Selfie" />
                                                <Button DockPanel.Dock="Right"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Height="30"
                                                        Padding="10,4"
                                                        Content="Chọn ảnh"
                                                        Name="btnSelfiImg"
                                                        Click="btnSelfiImg_Click" />
                                            </DockPanel>
                                        </StackPanel>

                                        <WrapPanel Margin="0,12,0,0">
                                            <Border Width="122"
                                                    Height="90"
                                                    Margin="0,0,10,0"
                                                    Background="White"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    ClipToBounds="True">
                                                <Image Name="imgFrontPreview" Stretch="UniformToFill" />
                                            </Border>

                                            <Border Width="122"
                                                    Height="90"
                                                    Margin="0,0,10,0"
                                                    Background="White"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    ClipToBounds="True">
                                                <Image Name="imgBackPreview" Stretch="UniformToFill" />
                                            </Border>

                                            <Border Width="122"
                                                    Height="90"
                                                    Background="White"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    ClipToBounds="True">
                                                <Image Name="imgSelfiePreview" Stretch="UniformToFill" />
                                            </Border>
                                        </WrapPanel>

                                        <StackPanel Margin="0,12,0,0">
                                            <Button Margin="0,10,0,0"
                                                    Height="36"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Content="Lưu hồ sơ eKYC"
                                                    Name="btnSaveEkyc"
                                                    IsEnabled="False"
                                                    Click="btnSaveEkyc_Click" />
                                        </StackPanel>
                                    </StackPanel>
                                </Expander>
                            </Border>

                            <Button Margin="0,18,0,0"
                                    Height="44"
                                    FontSize="14"
                                    Content="Đăng ký"
                                    Name="btnRegister" Click="btnRegister_Click" />

                            <TextBlock Margin="0,14,0,0"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource SubtleTextBrush}">
                                <Run Text="Đã có tài khoản? " />
                                <Run Text="Đăng nhập"
                                     TextDecorations="Underline"
                                     Foreground="{StaticResource PrimaryBrush}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
