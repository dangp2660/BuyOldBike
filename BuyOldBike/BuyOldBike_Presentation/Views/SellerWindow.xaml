<Window x:Class="BuyOldBike_Presentation.Views.SellerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BuyOldBike_Presentation.Converters"
        mc:Ignorable="d"
        Title="Khu vực Seller"
        Width="1200"
        Height="800"
        MinWidth="1024"
        MinHeight="640"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:HideShowConverter x:Key="HideShowConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#FFE5E7EB"
                BorderThickness="0,0,0,1"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Seller Center" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#FF6B7280"
                               Text="Quản lý đăng bán, đơn hàng và đánh giá" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Height="40" MinWidth="130" Content="Xem hồ sơ" />
                    <Button Margin="12,0,0,0" Height="40" MinWidth="130" Content="Ví / Nạp tiền" Click="BtnOpenWallet_Click" />
                    <Button Margin="12,0,0,0" Height="40" MinWidth="130" Content="Đăng xuất" Click="BtnLogout_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="16" Background="{x:Null}">
            <TabItem Header="Dashboard">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Tổng quan" />

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Grid.Column="0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                <StackPanel>
                                    <TextBlock Foreground="#FF6B7280" Text="Total Listings" />
                                    <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Text="12" />
                                    <TextBlock Margin="0,8,0,0" Foreground="#FF6B7280" Text="Số bài đăng đã tạo" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="2" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                <StackPanel>
                                    <TextBlock Foreground="#FF6B7280" Text="Active Listings" />
                                    <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Text="7" />
                                    <TextBlock Margin="0,8,0,0" Foreground="#FF6B7280" Text="Đang hiển thị cho người mua" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Grid.Column="0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                <StackPanel>
                                    <TextBlock Foreground="#FF6B7280" Text="Pending Orders" />
                                    <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Text="3" />
                                    <TextBlock Margin="0,8,0,0" Foreground="#FF6B7280" Text="Đơn chờ phản hồi" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Grid.Column="2" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                <StackPanel>
                                    <TextBlock Foreground="#FF6B7280" Text="Recent Messages" />
                                    <StackPanel Margin="0,10,0,0">
                                        <Border Background="#FFF3F4F6" CornerRadius="10" Padding="10">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="Nguyễn A" />
                                                <TextBlock Foreground="#FF6B7280" Text="Xe còn không bạn? Mình xin thêm ảnh..." />
                                            </StackPanel>
                                        </Border>
                                        <Border Margin="0,10,0,0" Background="#FFF3F4F6" CornerRadius="10" Padding="10">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="Trần B" />
                                                <TextBlock Foreground="#FF6B7280" Text="Cho mình hỏi size frame 54 có vừa 1m75 không?" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Create Listing">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Tạo bài đăng mới" />

                        <Border Margin="0,12,0,0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="16" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Title" />
                                <TextBox Grid.Row="0" Grid.Column="2" x:Name="txtTitle" />

                                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Description" />
                                <TextBox Grid.Row="2" Grid.Column="2" MinHeight="90" Padding="10,8" TextWrapping="Wrap" AcceptsReturn="True"
                                         Grid.RowSpan="2" 
                                         Name="txtDecription"/>

                                <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="Price" />
                                <TextBox Grid.Row="5" Grid.Column="2" Margin="0,27,0,27" Name="txtPrice" PreviewTextInput="txtPrice_PreviewTextInput" TextChanged="txtPrice_TextChanged" />

                                <TextBlock Grid.Row="7" Grid.Column="0" VerticalAlignment="Center" Text="Brand" />
                                <ComboBox Grid.Row="7" Grid.Column="2" SelectedIndex="0" Name="cbxBrand"/>

                                <TextBlock Grid.Row="9" Grid.Column="0" VerticalAlignment="Center" Text="Bike Type" />
                                <ComboBox Grid.Row="9" Grid.Column="2" SelectedIndex="0" Name="cbxBikeType"/>

                                <TextBlock Grid.Row="11" Grid.Column="0" VerticalAlignment="Center" Text="Frame Number" />
                                <TextBox Grid.Row="11" Grid.Column="2" x:Name="tbFrameNum" />

                                <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="Usage History" />
                                <TextBox Grid.Row="0" Grid.Column="6" x:Name="txtUsage" />

                                <TextBlock Grid.Row="3" Grid.Column="4" VerticalAlignment="Center" Text="Upload Images" />
                                <Border Grid.Row="2" Grid.Column="6"
                                        MinHeight="90"
                                        Background="#FFF3F4F6"
                                        BorderBrush="#FFE5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="10" Grid.RowSpan="2">
                                    <StackPanel>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock FontWeight="SemiBold" Text="Kéo thả ảnh vào đây" />
                                            <TextBlock Margin="0,4,0,0" Foreground="#FF6B7280" Text="Hoặc bấm nút chọn ảnh" Name="l"/>
                                            <Button Margin="0,10,0,0" Content="Chọn ảnh" Name="btnUpImage" Click="btnUpImage_Click"/>
                                            <Label Name="lblImageCount"/>
                                        </StackPanel>

                                        <TextBlock Margin="0,12,0,6" FontWeight="SemiBold" Text="Ảnh đã chọn" />
                                        <Border Background="White"
                                                BorderBrush="#FFE5E7EB"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="8">
                                            <ScrollViewer Height="120" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                                <ItemsControl ItemsSource="{Binding SelectedImagePreviews}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Width="72"
                                                                    Height="72"
                                                                    Margin="0,0,8,8"
                                                                    Background="#FFF3F4F6"
                                                                    CornerRadius="8"
                                                                    ClipToBounds="True">
                                                                <Image Source="{Binding}" Stretch="UniformToFill" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <TextBlock Grid.Row="5" Grid.Column="4" VerticalAlignment="Center" Text="Upload Video" />
                                <Border Grid.Row="5" Grid.Column="6"
                                        Height="90"
                                        Background="#FFF3F4F6"
                                        BorderBrush="#FFE5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="10">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock FontWeight="SemiBold" Text="Video (tuỳ chọn)" />
                                        <TextBlock Margin="0,4,0,0" Foreground="#FF6B7280" Text="Định dạng .mp4, tối đa 50MB" />
                                        <Button Margin="0,10,0,0" Content="Chọn video" />
                                    </StackPanel>
                                </Border>

                                <StackPanel Grid.Row="15" Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Left" Margin="68,0,0,0">
                                    <Button MinWidth="120" Height="40" Content="Cancel" Name="btnCancel" Click="btnCancel_Click" />
                                    <Button Margin="12,0,0,0" MinWidth="140" Height="40" Content="Publish Listing" Name="btnPublish" Click="btnPublish_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Manage Listings">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Quản lý bài đăng" />

                        <Border Margin="0,12,0,0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="2*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" FontWeight="SemiBold" Text="Title" />
                                    <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="Price" />
                                    <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="Status" />
                                    <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="Views" />
                                    <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="Actions" />
                                </Grid>

                                <Border Margin="0,12,0,0" BorderBrush="#FFE5E7EB" BorderThickness="0,1,0,0" />

                                <ItemsControl ItemsSource="{Binding SellerListings}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,12" BorderBrush="#FFE5E7EB" BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="2*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Title}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Price, StringFormat=N0}" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Status}" />
                                                    <TextBlock Grid.Column="3" Text="{Binding Views}" />
                                                    <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Left">
                                                        <Button MinWidth="72" Height="30" Padding="10,4" Margin="6,0,0,0" Content="Edit" Click="BtnEditListing_Click" />
                                                        <Button MinWidth="72" Height="30" Padding="10,4" Margin="6,0,0,0" Content="Delete" Click="BtnDeleteListing_Click" />
                                                        <Button MinWidth="72" Height="30" Padding="10,4" Margin="6,0,0,0" IsEnabled="{Binding CanToggle}" Content="{Binding Status, Converter={StaticResource HideShowConverter}}" Click="BtnToggleHide_Click" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
 
            <TabItem Header="Seller Orders">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Đơn hàng của tôi" />

                        <Border Margin="0,12,0,0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="2*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" FontWeight="SemiBold" Text="Buyer" />
                                    <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="Bicycle" />
                                    <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="Price" />
                                    <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="Deposit Status" />
                                    <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="Order Status" />
                                    <TextBlock Grid.Column="5" FontWeight="SemiBold" Text="Actions" />
                                </Grid>

                                <Border Margin="0,12,0,0" BorderBrush="#FFE5E7EB" BorderThickness="0,1,0,0" />

                                <ItemsControl ItemsSource="{Binding SellerOrders}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="10,12" BorderBrush="#FFE5E7EB" BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="2*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="2*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding BuyerName}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding BicycleTitle}" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Price, StringFormat=N0}" />
                                                    <TextBlock Grid.Column="3" Text="{Binding DepositStatus}" />
                                                    <TextBlock Grid.Column="4" Text="{Binding OrderStatus}" />
                                                    <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Left">
                                                        <Button MinWidth="72" Height="30" Padding="10,4" Margin="6,0,0,0" Content="Accept" Click="BtnAcceptOrder_Click" />
                                                        <Button MinWidth="72" Height="30" Padding="10,4" Margin="6,0,0,0" Content="Reject" Click="BtnRejectOrder_Click" />
                                                        <Button MinWidth="72" Height="30" Padding="10,4" Margin="6,0,0,0" Content="Completed" Click="BtnCompleteOrder_Click" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Ví">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="White"
                            BorderBrush="#FFE5E7EB"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="16"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Số dư ví" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Name="txtSellerWalletBalance"
                                       Text="0đ" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Background="White"
                            BorderBrush="#FFE5E7EB"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="16"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Height="34"
                                     VerticalContentAlignment="Center"
                                     Padding="10,0"
                                     Name="txtSellerTopUpAmount"
                                     PreviewTextInput="txtSellerTopUpAmount_PreviewTextInput"
                                     TextChanged="txtSellerTopUpAmount_TextChanged"
                                     Text="100000" />
                            <Button Grid.Column="2"
                                    Width="120"
                                    Height="34"
                                    Content="Nạp tiền"
                                    Click="BtnSellerTopUp_Click" />
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="2"
                              Name="dgSellerWalletTransactions"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              Background="White"
                              BorderBrush="#FFE5E7EB"
                              BorderThickness="1"
                              RowHeight="36">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Thời gian" Binding="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="160" />
                            <DataGridTextColumn Header="Loại" Binding="{Binding Type}" Width="120" />
                            <DataGridTextColumn Header="Chiều" Binding="{Binding DirectionText}" Width="90" />
                            <DataGridTextColumn Header="Số tiền" Binding="{Binding AmountText}" Width="120" />
                            <DataGridTextColumn Header="Ghi chú" Binding="{Binding Note}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Seller Reviews">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#FF111827" Text="Đánh giá" />

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                <StackPanel>
                                    <TextBlock Foreground="#FF6B7280" Text="Average Rating" />
                                    <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Text="4.6" />
                                    <TextBlock Margin="0,8,0,0" Foreground="#FF6B7280" Text="Trên thang 5" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                                <StackPanel>
                                    <TextBlock Foreground="#FF6B7280" Text="Total Reviews" />
                                    <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Text="18" />
                                    <TextBlock Margin="0,8,0,0" Foreground="#FF6B7280" Text="Tổng lượt đánh giá" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Margin="0,16,0,0" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="14" Padding="16">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Danh sách reviews" />
                                <Border Margin="0,12,0,0" Background="#FFF3F4F6" CornerRadius="12" Padding="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="4*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontWeight="SemiBold" Text="Buyer Name" />
                                        <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="Rating" />
                                        <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="Comment" />
                                    </Grid>
                                </Border>

                                <Border Margin="0,10,0,0" BorderBrush="#FFE5E7EB" BorderThickness="0,1,0,0" />
                                <Border Padding="12,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="4*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Nguyễn A" />
                                        <TextBlock Grid.Column="1" Text="5" />
                                        <TextBlock Grid.Column="2" Text="Giao dịch nhanh, mô tả đúng, xe rất đẹp." />
                                    </Grid>
                                </Border>

                                <Border BorderBrush="#FFE5E7EB" BorderThickness="0,1,0,0" />
                                <Border Padding="12,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="4*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Trần B" />
                                        <TextBlock Grid.Column="1" Text="4" />
                                        <TextBlock Grid.Column="2" Text="Tư vấn nhiệt tình, giao hàng đúng hẹn." />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
