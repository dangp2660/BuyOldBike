<Window x:Class="BuyOldBike_Presentation.Views.WalletWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Ví"
        Width="900"
        Height="680"
        MinWidth="720"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">
    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <Grid Background="#F9FAFB" Margin="24">
            <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="22" FontWeight="Bold" Text="Ví" />
            <TextBlock Margin="0,6,0,0" Foreground="#FF6B7280" Name="txtStatus" Text="Đang tải..." />
        </StackPanel>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#FFE5E7EB"
                BorderThickness="1"
                CornerRadius="16"
                Padding="18"
                Margin="0,16,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Foreground="#FF6B7280" Text="Số dư hiện tại" />
                    <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Name="txtBalance" Text="--" />
                </StackPanel>
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBox Width="160"
                             Height="34"
                             VerticalContentAlignment="Center"
                             Padding="10,0"
                             Name="txtTopUpAmount"
                             PreviewTextInput="txtTopUpAmount_PreviewTextInput"
                             TextChanged="txtTopUpAmount_TextChanged"
                             Text="100000" />
                    <Button Margin="12,0,0,0"
                            Width="120"
                            Height="34"
                            Content="Nạp tiền"
                            Click="BtnTopUp_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2"
                  Name="dgTransactions"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  Background="White"
                  BorderBrush="#FFE5E7EB"
                  BorderThickness="1"
                  RowHeight="36">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Thời gian" Binding="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="160" />
                <DataGridTextColumn Header="Loại" Binding="{Binding Type}" Width="120" />
                <DataGridTextColumn Header="Chiều" Binding="{Binding DirectionText}" Width="90" />
                <DataGridTextColumn Header="Số tiền" Binding="{Binding AmountText}" Width="120" />
                <DataGridTextColumn Header="Ghi chú" Binding="{Binding Note}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="3"
                Margin="0,12,0,0"
                HorizontalAlignment="Right"
                Width="120"
                Height="40"
                Content="Đóng"
                Click="Close_Click" />
    </Grid>
    </ScrollViewer>
</Window>
