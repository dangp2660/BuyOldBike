<Window x:Class="BuyOldBike_Presentation.Views.WithdrawRequestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Rút tiền"
        Width="560"
        Height="560"
        MinWidth="520"
        MinHeight="520"
        WindowStartupLocation="CenterOwner">
    <Border Background="#FFF9FAFB"
            Padding="22">
        <Border Background="White"
                BorderBrush="#FFE5E7EB"
                BorderThickness="1"
                CornerRadius="16"
                Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock FontSize="20"
                               FontWeight="Bold"
                               Text="Tạo yêu cầu rút tiền" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#FF6B7280"
                               Text="Admin sẽ xác nhận trước khi trừ tiền trong ví." />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock FontSize="12" Foreground="#FF6B7280" Text="Ngân hàng" />
                        <ComboBox Margin="0,8,0,0"
                                  Name="cbxBankName"/>

                        <TextBlock Margin="0,14,0,0" FontSize="12" Foreground="#FF6B7280" Text="Số tài khoản" />
                        <TextBox Margin="0,8,0,0" Name="txtAccountNumber" />

                        <TextBlock Margin="0,14,0,0" FontSize="12" Foreground="#FF6B7280" Text="Tên chủ tài khoản" />
                        <TextBox Margin="0,8,0,0" Name="txtAccountName" />

                        <TextBlock Margin="0,14,0,0" FontSize="12" Foreground="#FF6B7280" Text="Số tiền (VND)" />
                        <TextBox Margin="0,8,0,0"
                                 Name="txtAmount"
                                 PreviewTextInput="txtAmount_PreviewTextInput"
                                 TextChanged="txtAmount_TextChanged"
                                 Text="100000" />
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2"
                            Margin="0,16,0,0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button MinWidth="110"
                            Height="36"
                            Padding="14,6"
                            Content="Huỷ"
                            Click="Cancel_Click" />
                    <Button Margin="10,0,0,0"
                            MinWidth="120"
                            Height="36"
                            Padding="14,6"
                            Content="Tạo yêu cầu"
                            Click="Confirm_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
